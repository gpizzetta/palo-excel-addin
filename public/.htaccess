<IfModule mod_headers.c>
  # Ruban / dialogue Office : eviter un commands.js ou commands.html fige en cache (ancien "Palo action").
  <FilesMatch "^(commands\.html|commands\.js|palo-ename-picker\.html|palo-ename-ribbon\.js)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>

  SetEnvIfNoCase Origin "^https://([a-z0-9-]+\.)?officeapps\.live\.com$" CORS_ALLOW_ORIGIN=$0
  SetEnvIfNoCase Origin "^https://palo\.berdoz\.local$" CORS_ALLOW_ORIGIN=$0
  SetEnvIfNoCase Origin "^http://palo\.berdoz\.local$" CORS_ALLOW_ORIGIN=$0

  Header always set Access-Control-Allow-Origin "%{CORS_ALLOW_ORIGIN}e" env=CORS_ALLOW_ORIGIN
  Header always set Access-Control-Allow-Credentials "true" env=CORS_ALLOW_ORIGIN
  Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS" env=CORS_ALLOW_ORIGIN
  Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With" env=CORS_ALLOW_ORIGIN
  Header always merge Vary "Origin"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  # CORS : origine = schéma + Host courant (portal-129032, portal.berdoz.local, etc.). %{HTTP_HOST} est bien expandu ici.
  RewriteCond %{HTTP:Origin} ^https?://%{HTTP_HOST}$ [NC]
  RewriteRule .* - [E=CORS_ALLOW_ORIGIN:%{HTTP:Origin}]
  # Anciens manifestes vers functions.json : CORS via functions-metadata.php (fichier functions.json reste du JSON brut).
  RewriteRule ^functions\.json$ functions-metadata.php [L,QSA]
  RewriteCond %{REQUEST_METHOD} =OPTIONS
  RewriteRule ^ - [R=204,L]
</IfModule>
